# ── Reasoning engine ───────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key_here
REASONING_MODEL=openai/gpt-oss-120b

# ── GitHub adapter (Phase 2) ────────────────────────────────
# Generate at: https://github.com/settings/tokens
# Needs: repo (read-only) scope
GITHUB_TOKEN=your_github_token_here

# ── Jira adapter (Phase 2) ─────────────────────────────────
# Your Atlassian Cloud subdomain, e.g. https://yourorg.atlassian.net
JIRA_BASE_URL=https://yourorg.atlassian.net
# The email you use to log in to Jira
JIRA_EMAIL=you@yourorg.com
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# ── Supabase (Phase 5) ─────────────────────────────────────
# Find in: Supabase project → Settings → API
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ── Slack (Phase 6) ────────────────────────────────────────
# Create an incoming webhook at: api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Neo4j (Phase 7) ────────────────────────────────────────
# Create a free Aura instance at: console.neo4j.io
# URI format: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
